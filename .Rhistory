# Juvenile Salmon Passage Estimation Shiny App
# For rotary screw trap data analysis
library(shiny)
library(shinythemes)
library(tidyverse)
library(DT)
library(ggplot2)
library(mvtnorm)
library(splines)
#source function files
sapply(list.files("scripts/functions", pattern = "\\.R$", full.names = TRUE), source)
?selectInput
ui <- fluidPage(
sidebarLayout(
sidebarPanel(
#file input for multiple files
fileInput("files", "Upload Data Files", accept = c(".csv"), multiple = TRUE),
h5(strong("Tables that must be uploaded:")),
h5("catch, recapture, release, visit"),
dateInput("survey_start","Survey Start Date:"),
dateInput("survey_end","Survey End Date:"),
selectInput("sum.by","Sum by:",c("day",
"week",
"month",
"year"),selected = "week"),
uiOutput("fileList"),  # Output for the list of uploaded files
h4("Data List:"),
verbatimTextOutput("dataListNames"),  #output to display the names in dataList
actionButton("run_estimate", "Estimate Passage"),
downloadButton("downloadData", "Download Estimates")  # download button
),
mainPanel(
h4("Summary Output:"),
dataTableOutput("passage_estimate"),  # Output for cleaned data
)
)
)
