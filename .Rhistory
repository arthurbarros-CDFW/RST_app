recapture_table <- data.frame(
Field = c("site_name", "subsite_name", "visit_time",
"trap_visit_ID", "release_ID", "n"),
Type = c("text", "text", "datetime (ISO 8601)",
"text/integer", "text/integer", "integer"),
Description = c("Name of river/study site",
"Trap location identifier used when multiple traps at a site. Still use if only one trap at site.",
"Date and time when recapture occurred\n\nYYYY-MM-DDThh:mm:ss",
"Links recapture data to visit record",
"Links recapture data to release record",
"Number of recaptured fish"),
Required = c("Y", "Y", "Y", "Y", "Y", "Y")
)
recapture_table %>%
gt() %>%
opt_row_striping() %>%
cols_width(
Field ~ px(150),
Type ~ px(180),
Description ~ px(400),
Required ~ px(80)
)
